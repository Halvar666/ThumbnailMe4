[thumbnails]
columns=4
rows=4
thumb_width=320
gap=8
seek_mode=fast
timestamps=true

[frame_selection]
start_margin_percent=7.0
end_margin_percent=7.0
skip_dark_frames=false
skip_similar_frames=false
similar_threshold_percent=92.0
randomize_positions=false
randomize_percent=10.0
use_specific_timestep=false
timestep_seconds=60.0
show_info_text=true
info_text_position=upper-left
timestamp_position=lower-left

[output]
folder=output
same_source_folder=false
filename_suffix=
format=jpg
jpeg_quality=95

[appearance]
# language: en or cz
language=en
additional_title_enabled=true
additional_title_text=Generated by Thumbnail me
background_color=#141414
title_text_color=#ffffff
info_text_color=#e6e6e6
count_text_color=#d2d2d2
timestamp_text_color=#ffffff
timestamp_background_color=#000000
tile_border_enabled=true
tile_border_color=#464646
font=Segoe UI,10,-1,5,50,0,0,0,0,0
